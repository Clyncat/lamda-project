# ── mPAY Gateway ──────────────────────────────────────────────
MPAY_MERCHANT_ID=your-merchant-id
MPAY_CHANNEL_SECRET=your-channel-secret
MPAY_SERVICE_ID=your-service-id
MPAY_BASE_HOST=api.mpay.example.com
MPAY_BASE_PATH=/v1
MPAY_TIMEOUT_MS=30000

# ── AWS ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=ap-southeast-1
LAMBDA_FUNCTION_NAME=mpay-qr-lambda